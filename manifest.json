{
  "manifest_version": 3,
  "name": "AIPredictor Auto-Fetch",
  "version": "1.0",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.hgnice.club/*", "https://hgnice.club/*"],
  "content_scripts": [
    {
      "matches": ["https://www.hgnice.club/*", "https://hgnice.club/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
